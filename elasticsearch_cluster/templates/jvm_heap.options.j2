-Xms{{ es_recommended_jvm_mb }}m
-Xmx{{ es_recommended_jvm_mb }}m

-XX:+UseG1GC

-Djava.io.tmpdir={{ es_tmpdir | default('/tmp') }}

# Optional performance tuning (retain only if validated for your JVM)
-XX:+HeapDumpOnOutOfMemoryError
-XX:+ExitOnOutOfMemoryError
-XX:ErrorFile=hs_err_pid%p.log

# GC logging
-Xlog:gc*,gc+age=trace,safepoint:file=gc.log:utctime,level,pid,tags:filecount=32,filesize=64m
